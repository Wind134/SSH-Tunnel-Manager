<Window x:Class="SSHTunnelManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SSHTunnelManager.Converters"
        xmlns:svc="clr-namespace:SSHTunnelManager.Services"
        Title="SSH Tunnel Manager"
        Width="720" Height="600"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}"
        TextElement.Foreground="{DynamicResource AppFg}"
        TextElement.FontFamily="Segoe UI">

    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusToColor" />
        <conv:StatusToDotConverter x:Key="StatusToDot" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Grid Grid.Row="0" Margin="12,8,12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="+ Add Tunnel" Command="{Binding AddTunnelCommand}" Padding="12,6" Margin="0,0,8,0" />
            <Button Grid.Column="1" Content="Start All" Command="{Binding StartAllCommand}" Padding="12,6" Margin="0,0,8,0" />
            <Button Grid.Column="2" Content="Stop All" Command="{Binding StopAllCommand}" Padding="12,6" Margin="0,0,8,0" />
            <Button Grid.Column="4" Content="Settings" Command="{Binding SettingsCommand}" Padding="12,6" />
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="12,8,12,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="6" />
                <RowDefinition Height="160" />
            </Grid.RowDefinitions>

            <!-- Tunnel list -->
            <ListView Grid.Row="0"
                      ItemsSource="{Binding Tunnels}"
                      SelectedItem="{Binding SelectedTunnel}"
                      Background="Transparent"
                      BorderThickness="0,0,0,1"
                      BorderBrush="{DynamicResource BorderCol}">
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type svc:TunnelState}">
                        <Border BorderBrush="{DynamicResource BorderCol}"
                                BorderThickness="0,0,0,1"
                                Padding="4,8,4,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Status dot -->
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Status, Converter={StaticResource StatusToDot}}"
                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                           FontSize="18" VerticalAlignment="Center"
                                           Margin="0,0,12,0" />

                                <!-- Tunnel info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Config.Name}" FontWeight="SemiBold" FontSize="14" />
                                    <TextBlock FontSize="12" Opacity="0.7">
                                        <Run Text="{Binding Config.SshUser}" />
                                        <Run Text="@" />
                                        <Run Text="{Binding MaskedHost, Mode=OneWay}" />
                                        <Run Text=":" />
                                        <Run Text="{Binding Config.SshPort}" />
                                    </TextBlock>
                                    <TextBlock FontSize="11" Opacity="0.5">
                                        <Run Text="Local:" />
                                        <Run Text="{Binding Config.LocalPort}" />
                                        <Run Text=" -> Remote:" />
                                        <Run Text="{Binding Config.RemotePort}" />
                                    </TextBlock>
                                    <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.8" />
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Content="Start"
                                               Visibility="{Binding CanStart, Converter={StaticResource BoolToVis}}"
                                               Command="{Binding DataContext.StartTunnelCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                               CommandParameter="{Binding}"
                                               Margin="4,0,4,0" Padding="12,4" />
                                    <Button Content="Stop"
                                               Visibility="{Binding CanStop, Converter={StaticResource BoolToVis}}"
                                               Command="{Binding DataContext.StopTunnelCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                               CommandParameter="{Binding}"
                                               Margin="4,0,4,0" Padding="12,4" />
                                    <Button Content="Edit"
                                               Command="{Binding DataContext.EditTunnelCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                               CommandParameter="{Binding}"
                                               Margin="4,0,4,0" Padding="12,4" />
                                    <Button Content="Delete"
                                               Command="{Binding DataContext.DeleteTunnelCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                               CommandParameter="{Binding}"
                                               Margin="4,0,4,0" Padding="12,4" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1" HorizontalAlignment="Stretch" Background="{DynamicResource BorderCol}" />

            <!-- Log panel -->
            <Border Grid.Row="2" Padding="8" Background="{DynamicResource PanelBg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Log" FontWeight="SemiBold" FontSize="12" Opacity="0.7" Margin="0,0,0,4" />
                        <Button Grid.Column="1" Content="复制" Command="{Binding CopyLogCommand}" Padding="10,2" Margin="0,0,0,4" />
                    </Grid>
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding LogEntries}"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="11" />
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Padding="12,4,12,6"
                BorderBrush="{DynamicResource BorderCol}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="12" Opacity="0.7" />
        </Border>
    </Grid>
</Window>
