<Window x:Class="SSHTunnelManager.Views.AddEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="480" Height="660"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White"
        TextElement.Foreground="Black"
        TextElement.FontFamily="Microsoft YaHei UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,16,24,24">

            <!-- Import from SSH Config -->
            <TextBlock Text="从 SSH 配置导入" FontWeight="SemiBold" Margin="0,0,0,4" Opacity="0.7" />
            <Separator Margin="0,0,0,8" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="SshConfigCombo" Grid.Column="0"
                          SelectionChanged="SshConfigCombo_SelectionChanged"
                          DisplayMemberPath="Host" />
                <Button Grid.Column="1" Content="导入"
                        Click="ImportFromConfig_Click" Margin="8,0,0,0"
                        Width="80" Padding="0,4" />
            </Grid>

            <!-- Name -->
            <TextBlock Text="名称" FontWeight="SemiBold" Margin="0,0,0,4" />
            <TextBox x:Name="NameBox" Margin="0,0,0,16" />

            <TextBlock Text="SSH 连接" FontWeight="SemiBold" Margin="0,0,0,4" Opacity="0.7" />
            <Separator Margin="0,0,0,12" />

            <!-- SSH User -->
            <TextBlock Text="SSH 用户名" Margin="0,0,0,4" />
            <TextBox x:Name="SshUserBox" Margin="0,0,0,12" />

            <!-- SSH Host -->
            <TextBlock Text="SSH 地址" Margin="0,0,0,4" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <PasswordBox x:Name="HostBox" Grid.Column="0" />
                <Button x:Name="ToggleHostBtn" Grid.Column="1" Content="显示"
                        Click="ToggleHostBtn_Click" Margin="8,0,0,0" Width="60" />
            </Grid>

            <!-- SSH Port -->
            <TextBlock Text="SSH 端口" Margin="0,0,0,4" />
            <TextBox x:Name="SshPortBox" Text="22" Margin="0,0,0,16" />

            <TextBlock Text="认证方式" FontWeight="SemiBold" Margin="0,0,0,4" Opacity="0.7" />
            <Separator Margin="0,0,0,12" />

            <!-- Auth Method Radio -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <RadioButton x:Name="PasswordRadio" Content="密码" IsChecked="True"
                             Margin="0,0,24,0" Click="AuthMethod_Click" />
                <RadioButton x:Name="KeyRadio" Content="私钥"
                             Click="AuthMethod_Click" />
            </StackPanel>

            <!-- Password field -->
            <StackPanel x:Name="PasswordPanel" Margin="0,0,0,12">
                <TextBlock Text="密码" Margin="0,0,0,4" />
                <PasswordBox x:Name="PasswordBox" />
            </StackPanel>

            <!-- Key file field -->
            <StackPanel x:Name="KeyPanel" Margin="0,0,0,12" Visibility="Collapsed">
                <TextBlock Text="私钥文件" Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="KeyFileBox" Grid.Column="0" />
                    <Button Grid.Column="1" Content="浏览"
                            Click="BrowseKey_Click" Margin="8,0,0,0" Width="60" />
                </Grid>
            </StackPanel>

            <TextBlock Text="端口映射" FontWeight="SemiBold" Margin="0,0,0,4" Opacity="0.7" />
            <Separator Margin="0,0,0,12" />

            <!-- Local Port -->
            <TextBlock Text="本地代理端口（例如 Clash 的 7890）" Margin="0,0,0,4" />
            <TextBox x:Name="LocalPortBox" Text="7890" Margin="0,0,0,12" />

            <!-- Remote Port -->
            <TextBlock Text="远程映射端口（远程机器上）" Margin="0,0,0,4" />
            <TextBox x:Name="RemotePortBox" Text="1080" Margin="0,0,0,16" />

            <!-- Auto Reconnect -->
            <CheckBox x:Name="AutoReconnectBox" Content="自动重连" IsChecked="True"
                      Margin="0,0,0,24" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Click="Cancel_Click" Margin="0,0,12,0"
                        Width="100" Padding="0,6" />
                <Button Content="保存" Click="Save_Click" IsDefault="True"
                        Width="100" Padding="0,6" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
