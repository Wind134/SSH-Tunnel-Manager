<Window x:Class="SSHTunnelManager.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="White"
        TextElement.Foreground="Black"
        TextElement.FontFamily="Microsoft YaHei UI">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="SSH Tunnel Manager" FontSize="20" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,0,0,8" />
        <TextBlock Text="版本 1.0.0" Opacity="0.7" HorizontalAlignment="Center"
                   Margin="0,0,0,20" />
        <TextBlock Text="Built with .NET 8 + SSH.NET"
                   Opacity="0.5" FontSize="11" HorizontalAlignment="Center"
                   Margin="0,0,0,24" />
        <Button Content="关闭" Click="Close_Click" Width="100" HorizontalAlignment="Center" Padding="0,6" />
    </StackPanel>
</Window>
