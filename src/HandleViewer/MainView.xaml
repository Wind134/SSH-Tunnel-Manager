<UserControl x:Class="HandleViewer.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:models="clr-namespace:HandleViewer.Models"
       Background="{DynamicResource AppBg}"
       TextElement.Foreground="{DynamicResource AppFg}"
       TextElement.FontFamily="Microsoft YaHei UI"
        AllowDrop="True"
        DragEnter="FileLock_DragEnter"
        Drop="FileLock_Drop">

    <UserControl.Resources>
        <Style x:Key="StateDot" TargetType="Ellipse">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Fill" Value="#888" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="Listener">
                    <Setter Property="Fill" Value="#12B88E" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="Established">
                    <Setter Property="Fill" Value="#1C7ED6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CenteredComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="0,4" />
        </Style>
        <Style x:Key="DropZone" TargetType="Border">
            <Setter Property="BorderBrush" Value="#1C7ED6" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#F0F6FF" />
            <Setter Property="Padding" Value="24" />
        </Style>
    </UserControl.Resources>

    <TabControl Margin="0">

        <!-- Tab 1: 端口占用 -->
        <TabItem Header="端口占用">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Grid Grid.Row="0" Margin="12,10,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Name="RefreshBtn" Content="刷新" Click="Refresh_Click"
                            Padding="14,6" Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1" Name="KindFilter" Width="110" Margin="0,0,8,0"
                              SelectedIndex="0" SelectionChanged="Filter_Changed"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="全部" Tag="All" Style="{StaticResource CenteredComboBoxItem}" />
                        <ComboBoxItem Content="仅监听" Tag="Listener" Style="{StaticResource CenteredComboBoxItem}" />
                        <ComboBoxItem Content="仅连接" Tag="Established" Style="{StaticResource CenteredComboBoxItem}" />
                    </ComboBox>
                    <ComboBox Grid.Column="2" Name="FamilyFilter" Width="90" Margin="0,0,8,0"
                              SelectedIndex="0" SelectionChanged="Filter_Changed"
                              HorizontalContentAlignment="Center"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="全部协议" Tag="All" Style="{StaticResource CenteredComboBoxItem}" />
                        <ComboBoxItem Content="IPv4" Tag="IPv4" Style="{StaticResource CenteredComboBoxItem}" />
                        <ComboBoxItem Content="IPv6" Tag="IPv6" Style="{StaticResource CenteredComboBoxItem}" />
                    </ComboBox>
                    <TextBox Grid.Column="3" Name="SearchBox"
                             Padding="8,4" VerticalContentAlignment="Center"
                             ToolTip="按端口号、进程名或 PID 过滤"
                             TextChanged="Filter_Changed" />
                    <TextBlock Grid.Column="4" Text="系统进程" VerticalAlignment="Center" Margin="8,0,4,0" Opacity="0.7" />
                    <CheckBox Grid.Column="5" Name="ShowSystem" VerticalAlignment="Center"
                              IsChecked="True" Checked="Filter_Changed" Unchecked="Filter_Changed" />
                </Grid>

                <!-- Port table -->
               <DataGrid Grid.Row="1" Name="Grid"
                         Margin="12,0,12,8"
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         HeadersVisibility="Column"
                         GridLinesVisibility="Horizontal"
                         BorderBrush="{DynamicResource GridBorder}"
                         RowBackground="{DynamicResource GridBg}"
                         AlternatingRowBackground="{DynamicResource GridAltBg}"
                         CanUserSortColumns="True"
                         SelectionMode="Single"
                         SelectionUnit="FullRow"
                         ColumnHeaderHeight="28"
                         RowHeight="24">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="打开所在目录" Click="OpenDirectory_Click" />
                            <MenuItem Header="终止进程" Click="KillProcess_Click" />
                            <Separator />
                            <MenuItem Header="复制行信息" Click="CopyRow_Click" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="32" SortMemberPath="Kind" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type models:PortOccupant}">
                                    <Ellipse Style="{StaticResource StateDot}" Margin="8,0,0,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="状态" Width="Auto" Binding="{Binding State}" />
                        <DataGridTextColumn Header="协议" Width="Auto" Binding="{Binding Family}" />
                        <DataGridTextColumn Header="本地地址" Width="Auto" Binding="{Binding LocalAddress}" />
                        <DataGridTextColumn Header="本地端口" Width="Auto" Binding="{Binding LocalPort}" />
                        <DataGridTextColumn Header="远程地址" Width="Auto" Binding="{Binding RemoteAddress}" />
                        <DataGridTextColumn Header="远程端口" Width="Auto" Binding="{Binding RemotePort, TargetNullValue=—}" />
                        <DataGridTextColumn Header="PID" Width="Auto" Binding="{Binding Pid}" />
                        <DataGridTextColumn Header="进程名" Width="Auto" Binding="{Binding ProcessName}" />
                        <DataGridTextColumn Header="可执行路径" Width="*" Binding="{Binding ProcessPath}" />
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Status bar -->
                <Border Grid.Row="2" Padding="12,6,12,8" BorderBrush="{DynamicResource GridBorder}" BorderThickness="0,1,0,0">
                    <TextBlock Name="StatusText" FontSize="12" Opacity="0.75" />
                </Border>
            </Grid>
        </TabItem>

        <!-- Tab 2: 文件锁查询 -->
        <TabItem Header="文件锁查询">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- File input bar -->
                <Grid Grid.Row="0" Margin="12,10,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Name="FilePathBox"
                             Padding="8,4" VerticalContentAlignment="Center"
                             ToolTip="输入文件路径,或拖拽文件到此处"
                             AllowDrop="True"
                             DragEnter="FileLock_DragEnter"
                             Drop="FileLock_Drop" />
                    <Button Grid.Column="1" Name="BrowseBtn" Content="浏览" Click="Browse_Click"
                            Padding="14,6" Margin="8,0,0,0" />
                </Grid>

                <!-- Drop zone / result table -->
                <Grid Grid.Row="1" Margin="12,0,12,8">
                    <!-- Drop hint (shown when no results) -->
                    <Border x:Name="DropHint" Style="{StaticResource DropZone}"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="将文件拖拽到此处" FontSize="18" HorizontalAlignment="Center" Opacity="0.6" />
                            <TextBlock Text="或点击上方&#x22;浏览...&#x22;选择文件" FontSize="12" HorizontalAlignment="Center" Opacity="0.4" Margin="0,8,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Lock results -->
                   <DataGrid x:Name="LockGrid"
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             HeadersVisibility="Column"
                             GridLinesVisibility="Horizontal"
                             BorderBrush="{DynamicResource GridBorder}"
                             RowBackground="{DynamicResource GridBg}"
                             AlternatingRowBackground="{DynamicResource GridAltBg}"
                             CanUserSortColumns="True"
                             SelectionMode="Single"
                             SelectionUnit="FullRow"
                             ColumnHeaderHeight="28"
                             RowHeight="24"
                             Visibility="Collapsed">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="打开所在目录" Click="LockOpenDirectory_Click" />
                                <MenuItem Header="终止进程" Click="LockKillProcess_Click" />
                                <Separator />
                                <MenuItem Header="复制行信息" Click="LockCopyRow_Click" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                       <DataGrid.Columns>
                           <DataGridTextColumn Header="PID" Width="Auto" Binding="{Binding Pid}" />
                           <DataGridTextColumn Header="进程名" Width="Auto" Binding="{Binding ProcessName}" />
                           <DataGridTextColumn Header="应用名称" Width="Auto" Binding="{Binding AppName}" />
                           <DataGridTextColumn Header="启动时间" Width="Auto" Binding="{Binding StartTime}" />
                           <DataGridTextColumn Header="可执行路径" Width="*" Binding="{Binding ProcessPath}" />
                       </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Status bar -->
                <Border Grid.Row="2" Padding="12,6,12,8" BorderBrush="{DynamicResource GridBorder}" BorderThickness="0,1,0,0">
                    <TextBlock Name="LockStatusText" FontSize="12" Opacity="0.75" />
                </Border>
            </Grid>
        </TabItem>

    </TabControl>
</UserControl>
