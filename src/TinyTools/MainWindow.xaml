<Window x:Class="TinyTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TinyTools" Width="960" Height="640"
        MinWidth="640" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}"
        TextElement.Foreground="{DynamicResource AppFg}"
        TextElement.FontFamily="Microsoft YaHei UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource PanelBg}" BorderBrush="{DynamicResource BorderCol}" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Sidebar header -->
                <TextBlock DockPanel.Dock="Top" Text="TinyTools" FontSize="20" FontWeight="Bold"
                           Margin="16,18,16,12" />
                <TextBlock DockPanel.Dock="Top" Text="工具集" FontSize="12" Opacity="0.5"
                           Margin="16,0,16,16" />

                <!-- Nav buttons -->
                <StackPanel Margin="4,0,4,8">
                    <Button x:Name="NavTunnel" Style="{StaticResource NavButtonActive}" Content="SSH 隧道管理" Click="Nav_Click" />
                    <Button x:Name="NavHandle" Style="{StaticResource NavButton}" Content="句柄查看器" Click="Nav_Click" />
                </StackPanel>

                <!-- Spacer + exit at bottom -->
                <StackPanel DockPanel.Dock="Bottom" Margin="4,0,4,12">
                    <Button Content="退出" Click="Exit_Click" Padding="16,8" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" />
                </StackPanel>
                <Border />
            </DockPanel>
        </Border>

        <!-- Content area -->
        <Grid Grid.Column="1">
            <!-- Placeholder; actual view swapped in code-behind -->
            <ContentControl x:Name="ContentArea" />
        </Grid>
    </Grid>
</Window>